{
  "name": "sogverse-bedrock-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Xbox Live session portal that redirects console Minecraft Bedrock players from a friends-list entry to a custom server.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "bedrock-portal": "^2.1.0",
    "dotenv": "^16.4.5",
    "prismarine-auth": "github:LucienHH/prismarine-auth#playfab"
  },
  "devDependencies": {
    "@types/node": "^20.19.32",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
