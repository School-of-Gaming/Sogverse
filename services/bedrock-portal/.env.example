# Public IP/hostname of the Bedrock server players will be redirected to
BEDROCK_SERVER_IP=play.example.com

# Port the Bedrock server listens on (UDP). Default 19132.
BEDROCK_SERVER_PORT=19132

# Xbox Live gamertag shown in the "World name" and presence. Purely cosmetic.
PORTAL_WORLD_NAME=Sogverse Server

# Host/gamertag shown as the session owner. Purely cosmetic.
PORTAL_HOST_NAME=Sogverse

# Session joinability: FriendsOfFriends | FriendsOnly | InviteOnly
PORTAL_JOINABILITY=FriendsOfFriends

# Cache-key label for prismarine-auth (any stable string; commonly the
# gamertag or email of the alt account). Actual auth happens via browser
# device-code flow on first run — sign in with the ALT account, never your
# main one.
PORTAL_ACCOUNT_USERNAME=sogverse-alt

# Where prismarine-auth caches Xbox tokens. Safe to leave as-is.
PORTAL_AUTH_CACHE_DIR=./.auth-cache
