{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "scripts/*.ts"
  ],
  "ignore": [
    "src/types/database.types.ts",
    "src/i18n/types.ts"
  ],
  "ignoreBinaries": [
    "stripe",
    "supabase"
  ],
  "ignoreDependencies": [
    "use-intl",
    "bedrock-portal-nethernet"
  ],
  "playwright": {
    "config": "playwright.config.ts",
    "entry": ["tests/e2e/**/*.spec.ts"]
  },
  "vitest": {
    "config": ["vitest.config.mts", "vitest.config.db.mts"]
  }
}
