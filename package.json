{
  "name": "sogverse-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:stripe": "concurrently --names next,stripe --prefix-colors blue,magenta \"next dev --turbopack\" \"stripe listen --forward-to localhost:3000/api/webhooks/stripe\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/ tests/",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "test:db": "vitest --run --config vitest.config.db.mts",
    "test:db:ui": "vitest --ui --config vitest.config.db.mts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:reset": "supabase db reset",
    "supabase:gen-types": "supabase gen types typescript --local > src/types/database.types.ts",
    "check-translations": "node scripts/check-translations.mjs"
  },
  "dependencies": {
    "@daily-co/daily-js": "^0.87.0",
    "@dnd-kit/core": "^6.3.1",
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tanstack/react-query": "^5.90.20",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns-tz": "^3.2.0",
    "discord-interactions": "^4.4.0",
    "eslint-plugin-i18next": "^6.1.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-phone-number-input": "^3.4.16",
    "stripe": "^17.7.0",
    "tailwind-merge": "^2.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.32",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^28.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
